#!/usr/bin/env bash

if ! command -v clang-format &>/dev/null; then
    echo "pre-commit: clang-format not found"
    exit 1
fi

staged=$(git diff --cached --name-only --diff-filter=ACM | grep -vE '(imath|sre|picolibc)/' || true)

[ -z "$staged" ] && exit 0

cfiles=$(echo "$staged" | grep -E '\.(sh|bash)')
cmakefiles=$(echo "$staged" | grep -E '(^|/)(CMakeLists\.txt|.*\.cmake)$')
shfiles=$(echo "$staged" | grep -E '\.(sh|bash)')

if [[ -n "$cfiles" ]]; then
    echo "$cfiles" | xargs clang-format -i
    echo "$cfiles" | xargs git add
fi

if command -v cmake-format >/dev/null 2>&1 && [[ -n "$cmakefiles" ]]; then
    printf '%s\n' "$cmakefiles" | xargs -r cmake-format -i
    printf '%s\n' "$cmakefiles" | xargs -r git add
fi

if command -v shfmt >/dev/null 2>&1 && [[ -n "$shfiles" ]]; then
    printf '%s\n' "$shfiles" | xargs -r shfmt -w
    printf '%s\n' "$shfiles" | xargs -r git add
fi
