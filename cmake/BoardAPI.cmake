function(tpl_board)
  cmake_parse_arguments(PARSE_ARGV 0 ARG
    ""
    "NAME;DESCRIPTION;LINKER_SCRIPT;ENTRY;PICOLIBC_CROSS_FILE;USE_SEMIHOST"
    "SOURCES;INCLUDE_DIRS")

  if(DEFINED ARG_NAME)
    set(TPL_BOARD_NAME "${ARG_NAME}" PARENT_SCOPE)
  endif()
  if(DEFINED ARG_DESCRIPTION)
    set(TPL_BOARD_DESCRIPTION "${ARG_DESCRIPTION}" PARENT_SCOPE)
  endif()
  if(DEFINED ARG_SOURCES)
    list(APPEND TPL_BOARD_SRCS ${ARG_SOURCES})
    set(TPL_BOARD_SRCS "${TPL_BOARD_SRCS}" PARENT_SCOPE)
  endif()
  if(DEFINED ARG_INCLUDE_DIRS)
    list(APPEND TPL_BOARD_INCLUDE_DIRS ${ARG_INCLUDE_DIRS})
    set(TPL_BOARD_INCLUDE_DIRS "${TPL_BOARD_INCLUDE_DIRS}" PARENT_SCOPE)
  endif()

  if(DEFINED ARG_LINKER_SCRIPT)
    set(TPL_LINKER_SCRIPT "${ARG_LINKER_SCRIPT}" CACHE FILEPATH "Linker script" FORCE)
    set(TPL_LINKER_SCRIPT "${ARG_LINKER_SCRIPT}" PARENT_SCOPE)
  endif()
  if(DEFINED ARG_ENTRY)
    set(TPL_ENTRY "${ARG_ENTRY}" CACHE FILEPATH "Startup entry source" FORCE)
    set(TPL_ENTRY "${ARG_ENTRY}" PARENT_SCOPE)
  endif()
  if(DEFINED ARG_PICOLIBC_CROSS_FILE)
    set(TPL_PICOLIBC_CROSS_FILE "${ARG_PICOLIBC_CROSS_FILE}" CACHE FILEPATH "picolibc cross file" FORCE)
    set(TPL_PICOLIBC_CROSS_FILE "${ARG_PICOLIBC_CROSS_FILE}" PARENT_SCOPE)
  endif()
  if(DEFINED ARG_USE_SEMIHOST)
    set(TPL_USE_SEMIHOST "${ARG_USE_SEMIHOST}" CACHE BOOL "Enable semihosting" FORCE)
    set(TPL_USE_SEMIHOST "${ARG_USE_SEMIHOST}" PARENT_SCOPE)
  endif()
endfunction()
